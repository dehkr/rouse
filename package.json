{
  "name": "rousejs",
  "version": "0.2.0",
  "description": "The JavaScript UI and state orchestrator for server-rendered HTML",
  "author": "dehkr <dehkr25@gmail.com>",
  "license": "MIT",
  "keywords": [
    "ssr",
    "server-rendered",
    "progressive-enhancement",
    "orchestrator",
    "reactive",
    "reactivity",
    "signals",
    "event-bus",
    "optimistic-ui",
    "html-first",
    "no-build"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dehkr/rouse.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./min": {
      "import": "./dist/index.min.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "check": "biome check",
    "format": "biome format --write"
  },
  "devDependencies": {
    "alien-signals": "^3.1.2",
    "@biomejs/biome": "2.4.4",
    "tsup": "^8.5.1",
    "typescript": "~5.9.3"
  }
}
