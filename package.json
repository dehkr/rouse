{
  "name": "rousejs",
  "version": "0.10.0",
  "description": "A JavaScript reactivity and state sync layer for server-rendered HTML",
  "author": "dehkr <dehkr25@gmail.com>",
  "license": "MIT",
  "keywords": [
    "hypermedia",
    "ssr",
    "server-rendered",
    "progressive-enhancement",
    "mpa",
    "multi-page-app",
    "html-first",
    "no-build",
    "buildless",
    "declarative",
    "directives",
    "reactive",
    "reactivity",
    "signals",
    "state-management",
    "state-sync",
    "two-way-binding",
    "optimistic-ui",
    "typescript",
    "web-components"
  ],
  "homepage": "https://github.com/dehkr/rouse#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dehkr/rouse.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./min": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.min.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "check": "biome check",
    "format": "biome format --write",
    "types": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "alien-signals": "^3.1.2",
    "tsup": "^8.5.1",
    "typescript": "~5.9.3"
  }
}